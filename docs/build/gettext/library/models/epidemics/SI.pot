#: ../../source/library/models/epidemics/SI.rst:50
#: 4df8c6ab4f2c4d418b2651227fea04c1
msgid "Node transitions follow two rules: 1) if a :math:`S` state node has :math:`I` state neighbors, each :math:`I` state neighbor transmits the infection to the :math:`S` state node with probability :math:`\\beta`; 2) once infected, the node remains infected forever."
msgstr ""

#: ../../source/library/models/epidemics/SI.rst:54
#: 9e0a82d1766146baa633547d6f6a5c03
msgid "SI model diagram"
msgstr ""

#: ../../source/library/models/epidemics/SI.rst:59
#: 3cbd64797096492cb8426b3e86412b9b
msgid "Node states are represented by a Boolean indicator vector :math:`h \\in \\{0,1\\}^N`, where :math:`h_i=1` denotes ``infected`` and :math:`h_i=0` denotes ``susceptible``. The update of the system at step :math:`k` is decomposed into three stages:"
msgstr ""

#: ../../source/library/models/epidemics/SI.rst:63
#: 9d2567cebd3745418f2f156809bc2ca8
msgid "Each infected neighbor :math:`j` of node :math:`i` transmits a log-probability contribution"
msgstr ""

#: ../../source/library/models/epidemics/SI.rst:65
#: c5db6382173f42ba968c60481ef4fc72
msgid "m_{ji}^{(k)} = h_j^{(k-1)} \\cdot \\log(1-\\beta)"
msgstr ""

#: ../../source/library/models/epidemics/SI.rst:69
#: a614c740a11d49548a5d0fdbe11d0118
msgid "Node :math:`i` collects contributions from all neighbors :math:`N(i)` to compute its infection probability"
msgstr ""

#: ../../source/library/models/epidemics/SI.rst:71
#: d45b3e74eeee4443b6ab555b0283a239
msgid "m_i^{(k)} = 1 - \\exp\\!\\left( \\sum_{j \\in N(i)} m_{ji}^{(k)} \\right)"
msgstr ""

#: ../../source/library/models/epidemics/SI.rst:75
#: 29e70f79ecb14cdc8556a6a97a9f870e
msgid "The indicator variable is updated with independent uniform random variables :math:`U_i^{\\mathrm{inf}} \\sim \\mathrm{Uniform}(0,1)`:"
msgstr ""

#: ../../source/library/models/epidemics/SI.rst:77
#: 8b072722fdcc412f9a80e99e1e16f619
msgid "h_i^{(k)} =\n"
"\\begin{cases}\n"
"   1, & \\text{if } h_i^{(k-1)}=0 \\land (U_i^{\\mathrm{inf}} < m_i^{(k)}), \\\\[4pt]\n"
"   h_i^{(k-1)}, & \\text{otherwise}.\n"
"\\end{cases}"
msgstr ""

