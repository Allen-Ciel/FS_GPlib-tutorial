#: ../../source/library/models/epidemics/SI.rst:3
#: ce598d1352bf4c4fb70cbec2407952bc
msgid "The SI Model [1]_ assumes that infection spreads only through links between neighboring nodes in a graph :math:`G=(V,E)`. Each node is in one of two states: :math:`S` (susceptible) or :math:`I` (infected). A susceptible node :math:`i` becomes infected by its infected neighbors :math:`j \\in N(i)` with rate :math:`\\beta`:"
msgstr ""

#: ../../source/library/models/epidemics/SI.rst:7
#: 1a49ff3e77b64aa9916b2c3cbe4bb38a
msgid "\\begin{aligned}\n"
"\\frac{dS_i}{dt} &= -\\beta \\sum_{j\\in N(i)} S_i I_j, \\\\\n"
"\\frac{dI_i}{dt} &= \\beta \\sum_{j\\in N(i)} S_i I_j .\n"
"\\end{aligned}"
msgstr ""

