#: ../../source/library/models/epidemics/SIR.rst:55
#: 23d745e41b0d434aa17936b47eab349e
msgid "Node transitions follow two rules: 1) if a :math:`S` state node has :math:`I` state neighbors, each :math:`I` state neighbor transmits the infection to the :math:`S` state node with probability :math:`\\beta`; 2) the :math:`I` state node is recovered to the :math:`R` state with probability :math:`\\gamma`."
msgstr ""

#: ../../source/library/models/epidemics/SIR.rst:60
#: eb8d4d1a96354f9db2ca76f69a0c7e63
msgid "SIR model diagram"
msgstr ""

#: ../../source/library/models/epidemics/SIR.rst:65
#: 07f34a3aa5a54f0292905e00c253325b
msgid "Node states are represented by two Boolean indicator vectors :math:`h, r \\in \\{0,1\\}^N`, where :math:`h_i=1` denotes ``infected``, :math:`r_i=1` denotes ``recovered``, and :math:`(h_i,r_i)=(0,0)` denotes ``susceptible``. The update of the system at step :math:`k` is decomposed into three stages:"
msgstr ""

#: ../../source/library/models/epidemics/SIR.rst:70
#: d3e4740fd9204c43b662153ac0c86728
msgid "Each infected neighbor :math:`j` of node :math:`i` transmits a log-probability contribution"
msgstr ""

#: ../../source/library/models/epidemics/SIR.rst:72
#: 05a848a9009d413db3695b26bb075633
msgid "m_{ji}^{(k)} = h_j^{(k-1)} \\cdot \\log(1-\\beta)"
msgstr ""

#: ../../source/library/models/epidemics/SIR.rst:77
#: 3c1e3819db1a4a70beffdaaa644f2528
msgid "Node :math:`i` collects contributions from all neighbors :math:`N(i)` to compute its infection probability"
msgstr ""

#: ../../source/library/models/epidemics/SIR.rst:79
#: 5367fdb81fdf4b2db4841b972eff8c61
msgid "m_i^{(k)} = 1 - \\exp\\!\\left( \\sum_{j \\in N(i)} m_{ji}^{(k)} \\right)"
msgstr ""

#: ../../source/library/models/epidemics/SIR.rst:84
#: ea10f44502c0435ea9c7329a07535dba
msgid "The indicator variables are updated with independent uniform random variables :math:`U_i^{\\mathrm{inf}}, U_i^{\\mathrm{rec}} \\sim \\mathrm{Uniform}(0,1)`"
msgstr ""

#: ../../source/library/models/epidemics/SIR.rst:86
#: ae28048d0a9b469cbf9ca9979fcd1850
msgid "\\begin{aligned}\n"
"    h_i^{(k)} &=\n"
"    \\begin{cases}\n"
"            1, & \\text{if } (h_i^{(k-1)}=0 \\land r_i^{(k-1)}=0) \\land (U_i^{\\mathrm{inf}} < m_i^{(k)}), \\\\[4pt]\n"
"            0, & \\text{if } h_i^{(k-1)}=1 \\land (U_i^{\\mathrm{rec}} \\ge \\gamma), \\\\[4pt]\n"
"            h_i^{(k-1)}, & \\text{otherwise},\n"
"    \\end{cases} \\\\[6pt]\n"
"    r_i^{(k)} &=\n"
"    \\begin{cases}\n"
"            1, & \\text{if } h_i^{(k-1)}=1 \\land (U_i^{\\mathrm{rec}} < \\gamma), \\\\[4pt]\n"
"            r_i^{(k-1)}, & \\text{otherwise}.\n"
"    \\end{cases}\n"
"\\end{aligned}"
msgstr ""

