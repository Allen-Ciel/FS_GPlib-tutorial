#: ../../source/library/models/epidemics/SIR.rst:4
#: 2064271cec3d42a8841bc12ee4bc3b32
msgid "The SIR Model [1]_ assumes that infection spreads only through links between neighboring nodes in a graph :math:`G=(V,E)`. Each node is in one of three states: :math:`S`, :math:`I`, or :math:`R`. A susceptible node :math:`i` is infected by its infected neighbors :math:`j \\in N(i)` with rate :math:`\\beta`, while infected nodes recover with rate :math:`\\gamma`:"
msgstr ""

#: ../../source/library/models/epidemics/SIR.rst:9
#: 7b0bde77f2df4840bb204962109daa63
msgid "\\begin{aligned}\n"
"\\frac{dS_i}{dt} &= -\\beta \\sum_{j\\in N(i)} S_i I_j, \\\\\n"
"\\frac{dI_i}{dt} &= \\beta \\sum_{j\\in N(i)} S_i I_j - \\gamma I_i, \\\\\n"
"\\frac{dR_i}{dt} &= \\gamma I_i .\n"
"\\end{aligned}"
msgstr ""

