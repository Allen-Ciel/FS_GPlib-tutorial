msgstr ""

#: ../../source/library/models/epidemics/SWIR.rst:55
#: 67b24d4c392e424bae55c73714be573e
msgid "the :math:`I` state node is recovered to the :math:`R` state with probability 1 **(I→R)**."
msgstr ""

#: ../../source/library/models/epidemics/SWIR.rst:59
