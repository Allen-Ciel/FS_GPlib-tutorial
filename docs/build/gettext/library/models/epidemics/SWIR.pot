#: ../../source/library/models/epidemics/SWIR.rst:64
#: 0c0e1ab7a7924452aedbd2c5a50474e1
msgid "We represent node states with three Boolean indicator vectors :math:`h, w, r \\in \\{0,1\\}^N`. Let :math:`N(i)` be the neighbor set of node :math:`i`. The update at discrete step :math:`k` is performed in the following stages (matching the reference implementation):"
msgstr ""

#: ../../source/library/models/epidemics/SWIR.rst:66
#: fbd6db9c032e42cab49467af55d8cadb
msgid ":math:`h_i=1` indicates node :math:`i` is ``infected`` or ``weakened``; :math:`h_i=0` indicates ``susceptible`` or ``recovered``."
msgstr ""

#: ../../source/library/models/epidemics/SWIR.rst:67
#: b0d6c0b5a6514085b239f487fb3e1262
msgid ":math:`(h_i,w_i,r_i)=(1,0,0)` denotes ``infected``, :math:`(h_i,w_i,r_i)=(1,1,0)` denotes ``weakened``."
msgstr ""

#: ../../source/library/models/epidemics/SWIR.rst:68
#: 98eeb05b676648dd96b21cc0e2caf4f9
msgid ":math:`(h_i,w_i,r_i)=(0,0,1)` denotes ``recovered``, :math:`(h_i,w_i,r_i)=(0,0,0)` denotes ``susceptible``."
msgstr ""

#: ../../source/library/models/epidemics/SWIR.rst:70
#: 6d642428128b41dd8e49d17c7858cbbc
msgid "Each infected neighbor :math:`j` of node :math:`i` transmits a log-probability contribution"
msgstr ""

#: ../../source/library/models/epidemics/SWIR.rst:72
#: 7db98396c4f64bf8a2c0c0c11e1a6b23
msgid "For each edge :math:`j\\to i`, an infected neighbor contributes to the log-survival; the per-step infection probability for node :math:`i` is"
msgstr ""

#: ../../source/library/models/epidemics/SWIR.rst:74
#: 9bb2a54518194721b0f9bb71c774f80d
msgid "m_{ji}^{(k)} = \\mathbf{1}\\!\\left(h_j^{(k-1)}=1 \\land w_j^{(k-1)}=0\\right) \\cdot \\log(1-\\kappa), \\qquad\n"
"I_i^{(k)} = 1 - \\exp\\!\\left( \\sum_{j\\in N(i)} m_{ji}^{(k)} \\right),"
msgstr ""

#: ../../source/library/models/epidemics/SWIR.rst:79
#: ac31dd5f6d8c4302afbf1552140b08c9
msgid "applied only to currently susceptible and not recovered nodes."
msgstr ""

#: ../../source/library/models/epidemics/SWIR.rst:81
#: 81542f51554c4289a351a35d407f47fb
msgid "**Weakening (S→W)**"
msgstr ""

#: ../../source/library/models/epidemics/SWIR.rst:83
#: 8e1aebb040df4af7a30433b8c367adc5
msgid "Analogously, the probability to become weakened is"
msgstr ""

#: ../../source/library/models/epidemics/SWIR.rst:85
#: 4d11d282aaca4ea79decfbc8e082989f
msgid "\\widetilde{m}_{ji}^{(k)} = \\mathbf{1}\\!\\left(h_j^{(k-1)}=1 \\land w_j^{(k-1)}=0\\right) \\cdot \\log(1-\\mu), \\qquad\n"
"W_i^{(k)} = 1 - \\exp\\!\\left( \\sum_{j\\in N(i)} \\widetilde{m}_{ji}^{(k)} \\right),"
msgstr ""

#: ../../source/library/models/epidemics/SWIR.rst:90
#: 8e6237ac29ae4f009ea4e5f25a81cd99
msgid "again only for nodes that are susceptible and not recovered."
msgstr ""

#: ../../source/library/models/epidemics/SWIR.rst:92
#: 0f1b704c6984422b921a81924d8824ab
msgid "**Weakened to infected (W→I)**"
msgstr ""

#: ../../source/library/models/epidemics/SWIR.rst:94
#: 9caf559ccd97464e9443d4a6274d073a
msgid "A weakened node may become infected via infected neighbors with rate :math:`\\nu`:"
msgstr ""

#: ../../source/library/models/epidemics/SWIR.rst:96
#: 3054d18efa4e4812b94ce656c7a2ca7b
msgid "\\widehat{m}_{ji}^{(k)} = \\mathbf{1}\\!\\left(h_j^{(k-1)}=1 \\land w_j^{(k-1)}=0\\right) \\cdot \\log(1-\\nu), \\qquad\n"
"WI_i^{(k)} = 1 - \\exp\\!\\left( \\sum_{j\\in N(i)} \\widehat{m}_{ji}^{(k)} \\right),"
msgstr ""

#: ../../source/library/models/epidemics/SWIR.rst:101
#: 13308d66b9994780b21aed2c227e34f4
msgid "applied only to currently weakened nodes (:math:`w_i^{(k-1)}=1`)."
msgstr ""

#: ../../source/library/models/epidemics/SWIR.rst:103
#: 78d92beb415e48d3893694923f4d41d4
msgid "**Recovery (I→R)**"
msgstr ""

#: ../../source/library/models/epidemics/SWIR.rst:105
#: 60ad84a3a27348c1816934c7dcba3e28
msgid "In this implementation, infected and not-weakened nodes deterministically recover at each step (no parameter :math:`\\gamma`). We model this as"
msgstr ""

#: ../../source/library/models/epidemics/SWIR.rst:107
#: bbfa16c575634601a73278350d541d60
msgid "r_i^{(k)} = r_i^{(k-1)} \\;\\lor\\; \\big( h_i^{(k-1)} = 1 \\land w_i^{(k-1)} = 0 \\big),"
msgstr ""

#: ../../source/library/models/epidemics/SWIR.rst:111
#: d5c8d6b05ebd43b3a33607d6bc683232
msgid "and recovered nodes remain immune: they neither get weakened nor re-infected."
msgstr ""

#: ../../source/library/models/epidemics/SWIR.rst:113
#: dac5354430f945808d6179e587f109d2
msgid "**Sampling and state update**"
msgstr ""

#: ../../source/library/models/epidemics/SWIR.rst:115
#: 930098e632be4b78a9a40ae72f808cd4
msgid "Let :math:`U_i^{\\mathrm{inf}}, U_i^{\\mathrm{wk}}, U_i^{\\mathrm{wi}} \\sim \\mathrm{Uniform}(0,1)` be independent. The indicators are updated as"
msgstr ""

#: ../../source/library/models/epidemics/SWIR.rst:117
#: 58e327a3bc7c4fd98df6ed0b6ec45d9b
msgid "\\begin{aligned}\n"
"w_i^{(k)} &= \\begin{cases}\n"
"   1, & \\text{if } w_i^{(k-1)}=0 \\land r_i^{(k-1)}=0 \\land U_i^{\\mathrm{wk}} < W_i^{(k)}, \\\\\n"
"   0, & \\text{if } w_i^{(k-1)}=1 \\land U_i^{\\mathrm{wi}} < WI_i^{(k)}, \\\\\n"
"   w_i^{(k-1)}, & \\text{otherwise},\n"
"\\end{cases} \\\\\n"
"h_i^{(k)} &= \\begin{cases}\n"
"   1, & \\text{if } h_i^{(k-1)}=0 \\land r_i^{(k-1)}=0 \\land U_i^{\\mathrm{inf}} < I_i^{(k)}, \\\\\n"
"   1, & \\text{if } w_i^{(k-1)}=1 \\land U_i^{\\mathrm{wi}} < WI_i^{(k)}, \\\\\n"
"   0, & \\text{if } h_i^{(k-1)}=1 \\land w_i^{(k-1)}=0 \\text{ (recovery)}, \\\\\n"
"   h_i^{(k-1)}, & \\text{otherwise},\n"
"\\end{cases}\n"
"\\end{aligned}"
msgstr ""

#: ../../source/library/models/epidemics/SWIR.rst:133
#: 8d9430d90d4049c79217f5070fa12735
msgid "which mirrors the code path: S→W, S→I, W→I, I→R."
msgstr ""

