#: ../../source/library/models/epidemics/SEIS_ct.rst:49
#: 30024f25f3864ea4a52eed16716f6899
msgid "We use two Boolean indicator vectors :math:`h, e \\in \\{0,1\\}^N` and two integer tensors that store **entry times**:"
msgstr ""

#: ../../source/library/models/epidemics/SEIS_ct.rst:51
#: 4cf47025ad264c98892923b57147a1e8
msgid ":math:`h_i=1` indicates node :math:`i` is ``infected`` or ``exposed``; :math:`h_i=0` indicates ``susceptible``."
msgstr ""

#: ../../source/library/models/epidemics/SEIS_ct.rst:52
#: 9f41fa5add884e9faf4af7977d1f63c1
msgid ":math:`(h_i,e_i)=(0,0)` denotes **Susceptible (S)**."
msgstr ""

#: ../../source/library/models/epidemics/SEIS_ct.rst:53
#: 89350f33eaae4bc39f114c9f9a116229
msgid ":math:`(h_i,e_i)=(1,1)` denotes **Exposed (E)**."
msgstr ""

#: ../../source/library/models/epidemics/SEIS_ct.rst:54
#: 650107498be940e9a071c5dacf347949
msgid ":math:`(h_i,e_i)=(1,0)` denotes **Infected (I)**."
msgstr ""

#: ../../source/library/models/epidemics/SEIS_ct.rst:55
#: 6a4fa045da9e4ff6a4b2eab108275a9c
msgid ":math:`t_i^{E}` records the iteration :math:`k` when node :math:`i` **entered E**."
msgstr ""

#: ../../source/library/models/epidemics/SEIS_ct.rst:56
#: 5c0252cb6a1d43c38d60894e23e92a2a
msgid ":math:`t_i^{I}` records the iteration :math:`k` when node :math:`i` **entered I**."
msgstr ""

#: ../../source/library/models/epidemics/SEIS_ct.rst:58
#: 0fafe5ba22f24262befd9370c60f2ef5
msgid "With :math:`k` denoting the current iteration, define duration variables :math:`\\Delta t_i^{E} = k - t_i^{E}` and :math:`\\Delta t_i^{I} = k - t_i^{I}`. The update of the system at step :math:`k` is decomposed into three stages:"
msgstr ""

#: ../../source/library/models/epidemics/SEIS_ct.rst:63
#: 93cc8046eef94313b70c757855dd82b2
msgid "SEISct model diagram"
msgstr ""

#: ../../source/library/models/epidemics/SEIS_ct.rst:68
#: 917b405562e644478aa0d28cb5534430
msgid "Each infected neighbor :math:`j` of node :math:`i` transmits a log-probability contribution for exposure (S→E)"
msgstr ""

#: ../../source/library/models/epidemics/SEIS_ct.rst:70
#: 7ad7c051d06048fd825e9f543649cb7d
msgid "m_{ji}^{(k)} = \\mathbf{1}\\!\\left(h_j^{(k-1)}=1 \\land e_j^{(k-1)}=0\\right)\\,\\log(1-\\beta)"
msgstr ""

#: ../../source/library/models/epidemics/SEIS_ct.rst:76
#: 0e54e91bb59444669f24108fec00767c
msgid "Node :math:`i` collects contributions from all neighbors :math:`N(i)` to compute its exposure probability"
msgstr ""

#: ../../source/library/models/epidemics/SEIS_ct.rst:78
#: fd6b30a5e84a4091b4bb1606cf0f072c
msgid "m_i^{(k)} = 1 - \\exp\\!\\left( \\sum_{j \\in N(i)} m_{ji}^{(k)} \\right)"
msgstr ""

#: ../../source/library/models/epidemics/SEIS_ct.rst:83
#: 6670b952be7a4718bb35bf076b9030bf
msgid "The integer tensors and indicator variables are updated with independent uniform random variables :math:`U_i^{\\mathrm{exp}}, U_i^{\\mathrm{inf}}, U_i^{\\mathrm{rec}} \\sim \\mathrm{Uniform}(0,1)`"
msgstr ""

#: ../../source/library/models/epidemics/SEIS_ct.rst:87
#: 26a64850ce9c46758467865f9230025e
msgid "\\begin{aligned}\n"
"t_i^E &= k, \\text{if } (U_i^{\\mathrm{exp}}<m_i^{(k)}) \\land h_i^{(k-1)}=0 \\\\\n"
"t_i^I &= k, \\text{if } (U_i^{\\mathrm{inf}}<1-exp(-\\alpha \\cdot \\Delta t_i^E)) \\land e_i^{(k-1)}=1\n"
"\\end{aligned}\n"
"\n"
""
msgstr ""

#: ../../source/library/models/epidemics/SEIS_ct.rst:93
#: e9e7eb16933740faaaafd3a914d683df
msgid "\\begin{aligned}\n"
" h_i^{(k)} &=\n"
"\\begin{cases}\n"
"    1, & \\text{if } (U_i^{\\mathrm{exp}} < m_i^{(k)}) \\land h_i^{(k-1)}=0 \\\\[4pt]\n"
"    0, & \\text{if } (U_i^{\\mathrm{rec}} < 1-exp(-\\gamma\\cdot \\Delta t_i^I)) \\land (h_i^{(k-1)}=1 \\land e_i^{(k-1)}=0), \\\\[4pt]\n"
"    h_i^{(k-1)}, & \\text{otherwise},\n"
"\\end{cases} \\\\[6pt]\n"
"e_i^{(k)} &=\n"
"\\begin{cases}\n"
"    1, & \\text{if } (U_i^{\\mathrm{exp}} < m_i^{(k)}) \\land h_i^{(k-1)}=0 \\\\[4pt]\n"
"    0, & \\text{if } (U_i^{\\mathrm{inf}} < 1-exp(-\\alpha \\cdot \\Delta t_i^E)) \\land e_i^{(k-1)}=1 , \\\\[4pt]\n"
"    e_i^{(k-1)}, & \\text{otherwise},\n"
"\\end{cases}\n"
"\\end{aligned}\n"
"\n"
""
msgstr ""

