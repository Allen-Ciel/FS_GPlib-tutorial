#: ../../source/library/models/opinions/HK.rst:63
#: a83320c993ab463888bd99adfeb55476
msgid ""
"Unlike the SIR model with three discrete states, the HK model uses a "
"continuous opinion space. To avoid infinitely many states, we consider "
"only two cases (Figure \\ref{fig:HK}): if $\\#\\Gamma_\\epsilon=0$, the "
"opinion remains unchanged; otherwise, it is updated to the "
"$\\epsilon$-neighbors’ average."
msgstr ""

#: ../../source/library/models/opinions/HK.rst:65
#: c49f436bd0534376a3f0e30323682659
msgid "HK model diagram"
msgstr ""

#: ../../source/library/models/opinions/HK.rst:71
#: 8a69db12836041a1b958a746c05564e1
msgid "For each neighbor :math:`j \\in N(i)`, generate two message terms:"
msgstr ""

#: ../../source/library/models/opinions/HK.rst:73
#: d1aac0db08ff44ec9cb7f4c7a947a82a
msgid ""
"\\begin{aligned}\n"
"    m_{ji\\_c}^{(k)} &=\\mathbf{1}\\!\\left( |h_i^{(k-1)} - h_j^{(k-1)}| "
"< \\varepsilon \\right) \\cdot h_j^{(k-1)}, \\\\[6pt]\n"
"    m_{ji\\_v}^{(k)} &= \\mathbf{1}\\!\\left( |h_i^{(k-1)} - h_j^{(k-1)}|"
" < \\varepsilon \\right).\n"
"\\end{aligned}"
msgstr ""

#: ../../source/library/models/opinions/HK.rst:80
#: d08635e3425345d7aa2bbba1c62223af
msgid "where :math:`\\mathbf{1}(\\cdot)` is the indicator function."
msgstr ""

#: ../../source/library/models/opinions/HK.rst:82
#: 1b063ee34af1454a8cb74f7b467a64c9
msgid ""
"Node :math:`i` aggregates received messages by averaging opinions of "
":math:`\\varepsilon`-neighbors:"
msgstr ""

#: ../../source/library/models/opinions/HK.rst:84
#: 21aa16a062944a98aa9509a5c9f0a8e8
msgid ""
"\\begin{aligned}\n"
"    m_i^{(k)} &=\n"
"    \\begin{cases}\n"
"        \\dfrac{\\sum\\limits_{j \\in N(i)} "
"m_{ji\\_c}^{(k)}}{\\sum\\limits_{j \\in N(i)} m_{ji\\_v}^{(k)}},\n"
"        & \\text{if } \\sum\\limits_{j \\in N(i)} m_{ji\\_v}^{(k)} > 0, "
"\\\\[8pt]\n"
"    \\mathrm{NaN}, & \\text{otherwise}.\n"
"    \\end{cases} \\\\[10pt]\n"
"\\end{aligned}"
msgstr ""

#: ../../source/library/models/opinions/HK.rst:96
#: de94ad1baba743f5811fd5cdbd049bc7
msgid "Finally, the opinion of node :math:`i` is updated as"
msgstr ""

#: ../../source/library/models/opinions/HK.rst:98
#: 9a8c6d141fde4833a5788fd3c85f5837
msgid ""
"    \\begin{aligned}\n"
"    h_i^{(k)} &=\n"
"    \\begin{cases}\n"
"            m_i^{(k)}, & \\text{if } m_i^{(k)} \\neq \\mathrm{NaN}, "
"\\\\[6pt]\n"
"            h_i^{(k-1)}, &  \\text{otherwise}.\n"
"    \\end{cases}\n"
"\\end{aligned}"
msgstr ""

