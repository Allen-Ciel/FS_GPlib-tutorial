#: ../../source/library/models/opinions/HK.rst:5
#: f967a1aac6f14729a66763783e96b00a
msgid ""
"The HK model [1]_ describes continuous opinion dynamics. Each node holds "
"an initial opinion :math:`h \\in [-1,1]` and updates it in discrete "
"rounds. At each step: 1) :math:`\\epsilon` neighbor identification: find "
"the set :math:`\\Gamma_\\epsilon` of each node, :math:`d_{i,j}=\\left"
"|h_i-h_j\\right|\\le\\epsilon`, :math:`j\\in\\Gamma_\\epsilon`; 2) update"
" the opinion value: The opinion of node :math:`i` at the next time step "
"is updated as follows:"
msgstr ""

#: ../../source/library/models/opinions/HK.rst:12
#: bfb5b6d2c9d447ce936682bd6aabd5b7
msgid "h_i^{\\left(k\\right)}=\\frac{\\sum_{j\\in\\Gamma_\\epsilon}{h_j^{\\left(k-1\\right)}}}{\\#\\Gamma_\\epsilon}"
msgstr ""

#: ../../source/library/models/opinions/HK.rst:17
#: 1816e1ca765f467ca53f1457ce3ab5ce
msgid ""
"where :math:`\\#\\Gamma_\\epsilon` denotes the number of "
":math:`\\epsilon` neighbors."
msgstr ""

