#: ../../source/library/models/epidemics/SEIS_ct.rst:68
#: 917b405562e644478aa0d28cb5534430
msgid ""
"Each infected neighbor :math:`j` of node :math:`i` transmits a log-"
"probability contribution for exposure (S→E)"
msgstr "每个受感染的邻居:math:`j' 节点:math:`i ' 传递接触的日志概率(S E)"

#: ../../source/library/models/epidemics/SEIS_ct.rst:70
#: 7ad7c051d06048fd825e9f543649cb7d
msgid ""
"m_{ji}^{(k)} = \\mathbf{1}\\!\\left(h_j^{(k-1)}=1 \\land "
"e_j^{(k-1)}=0\\right)\\,\\log(1-\\beta)"
msgstr "m {ji}^{(k)}=\\ mathbf{1}\\!}\\左(h j^{(k-1)}\\land e j^{(k-1)\\0\\右)\\,\\log(1-\\β)"

#: ../../source/library/models/epidemics/SEIS_ct.rst:76
#: 0e54e91bb59444669f24108fec00767c
msgid ""
"Node :math:`i` collects contributions from all neighbors :math:`N(i)` to "
"compute its exposure probability"
msgstr "节点 : math:`i'收集所有邻居的贡献 : math:`N(i)'计算其暴露概率"

#: ../../source/library/models/epidemics/SEIS_ct.rst:78
#: fd6b30a5e84a4091b4bb1606cf0f072c
msgid "m_i^{(k)} = 1 - \\exp\\!\\left( \\sum_{j \\in N(i)} m_{ji}^{(k)} \\right)"
msgstr "m i^{(k)}=1 -\\exp\\!\\左(\\sum {j\\in N(i)} m {ji}^{(k)}\\右)"

#: ../../source/library/models/epidemics/SEIS_ct.rst:83
#: 6670b952be7a4718bb35bf076b9030bf
msgid ""
"The integer tensors and indicator variables are updated with independent "
"uniform random variables :math:`U_i^{\\mathrm{exp}}, U_i^{\\mathrm{inf}}, "
"U_i^{\\mathrm{rec}} \\sim \\mathrm{Uniform}(0,1)`"
msgstr ""
"整数计数器和指标变量以独立的统一随机变量更新 : math : 'U i^{\\ mathrm{exp}}, U i^{\\ mathrm{inf}},"
" U i^{\\ mathrm{rec}}\\sim\\mathrm{Uniform}(0,1)'"

#: ../../source/library/models/epidemics/SEIS_ct.rst:87
#: 26a64850ce9c46758467865f9230025e
msgid ""
"\\begin{aligned}\n"
"t_i^E &= k, \\text{if } (U_i^{\\mathrm{exp}}<m_i^{(k)}) \\land h_i^{(k-1)}=0 \\\\\n"
"t_i^I &= k, \\text{if } (U_i^{\\mathrm{inf}}<1-exp(-\\alpha \\cdot \\Delta t_i^E)) \\land e_i^{(k-1)}=1\n"
"\\end{aligned}\n"
"\n"
msgstr ""
"开始{对齐}\n"
"t i^E & k,\\text{if} (U i^{\\mathrm{exp}}<m i^{(k)})\\land h i^{(k-1)}\\\\\\0\n"
"t i^I \\ k,\\ text{if} (U i i mathrm{inf}}<1-exp(-\\ alpha\\cdot\\Delta t i^E))\\land e i^{(k-1)\\1)\\1\n"
"结束{对齐}"

#: ../../source/library/models/epidemics/SEIS_ct.rst:93
#: e9e7eb16933740faaaafd3a914d683df
msgid ""
"\\begin{aligned}\n"
" h_i^{(k)} &=\n"
"\\begin{cases}\n"
"    1, & \\text{if } (U_i^{\\mathrm{exp}} < m_i^{(k)}) \\land h_i^{(k-1)}=0 \\\\[4pt]\n"
"    0, & \\text{if } (U_i^{\\mathrm{rec}} < 1-exp(-\\gamma\\cdot \\Delta t_i^I)) \\land (h_i^{(k-1)}=1 \\land e_i^{(k-1)}=0), \\\\[4pt]\n"
"    h_i^{(k-1)}, & \\text{otherwise},\n"
"\\end{cases} \\\\[6pt]\n"
"e_i^{(k)} &=\n"
"\\begin{cases}\n"
"    1, & \\text{if } (U_i^{\\mathrm{exp}} < m_i^{(k)}) \\land h_i^{(k-1)}=0 \\\\[4pt]\n"
"    0, & \\text{if } (U_i^{\\mathrm{inf}} < 1-exp(-\\alpha \\cdot \\Delta t_i^E)) \\land e_i^{(k-1)}=1 , \\\\[4pt]\n"
"    e_i^{(k-1)}, & \\text{otherwise},\n"
"\\end{cases}\n"
"\\end{aligned}\n"
"\n"
msgstr ""
"开始{对齐}\n"
"h(k)}\n"
"开始{ cases}\n"
"1, &\\ text{if} (U i^{\\ mathrm{exp} < m i^{(k)})\\land h i^{(k-1)}\\\\[4pt]\n"
"0, &\\text{if} (U i ^{\\mathrm{rec} < 1-exp(-\\gamma\\cdot\\Delta t i^I))\\land(h i^{(k-1)\\1)\\i^{(k-1)\\0)\\[4pt]\n"
"h i^{(k-1)}, &\\ text{另类},\n"
"\\ end{ cases}\\\\\\ [6pt]\n"
"e i^{(k) }\n"
"开始{ cases}\n"
"1, &\\ text{if} (U i^{\\ mathrm{exp} < m i^{(k)})\\land h i^{(k-1)}\\\\[4pt]\n"
"0, &\\ text{if} (U i^{\\ mathrm{inf}}} < 1-exp(-\\ alpha\\cdot\\Delta t i^E))\\land e i^{(k-1)}\\\\[4pt]\n"
"e i  (k-1)}, &\\ text{另类},\n"
"结束{ cases}\n"
"结束{对齐}"

