#: ../../source/library/models/epidemics/SEIS.rst:71
#: f7682c5c86224ce89765c6ee9bc9fdfe
msgid ""
"We represent node states with two Boolean indicator vectors :math:`h, e \\in"
" \\{0,1\\}^N`:"
msgstr "我们代表两个布尔指标矢量的节点状态:`h, e\\ in \\{0, 1\\}^n':"

#: ../../source/library/models/epidemics/SEIS.rst:73
#: c54eabf740c04a41b79041b0c77ba3af
msgid ":math:`(h_i,e_i)=(0,0)` denotes **Susceptible (S)**,"
msgstr ":math:`(h i,e i)=(0,0)'表示**可接受(S)**,"

#: ../../source/library/models/epidemics/SEIS.rst:74
#: cb6e6c8849d44bf7b885c893240e987b
msgid ":math:`(h_i,e_i)=(1,1)` denotes **Exposed (E)**,"
msgstr ":math:`(h i,e i)=(1,1)'表示** 已出口(E)**,"

#: ../../source/library/models/epidemics/SEIS.rst:75
#: fd85b15a9d9648e98329fe874f49f5ce
msgid ":math:`(h_i,e_i)=(1,0)` denotes **Infected (I)**."
msgstr ":math:`(h i,e i)=(1,0)'表示**感染(I)**。"

#: ../../source/library/models/epidemics/SEIS.rst:78
#: 159be57c4fd146eba02da8259a9db4a3
msgid ""
"The update of the system at step :math:`k` is decomposed into three stages:"
msgstr "系统分三个阶段更新:"

#: ../../source/library/models/epidemics/SEIS.rst:80
#: a49169b310ae4b23954ab99cb021c33f
msgid ""
"Each infected neighbor :math:`j` of node :math:`i` transmits a log-"
"probability contribution for exposure (S→E)"
msgstr "每个受感染的邻居:math:`j' 节点:math:`i ' 传递接触的日志概率(S E)"

#: ../../source/library/models/epidemics/SEIS.rst:82
#: 13b46a87af484f69a44b3a81b03b2e9c
msgid ""
"m_{ji}^{(k)} = \\mathbf{1}\\!\\left(h_j^{(k-1)}=1 \\land "
"e_j^{(k-1)}=0\\right)\\,\\log(1-\\beta)"
msgstr "m {ji}^{(k)}=\\ mathbf{1}\\!}\\左(h j^{(k-1)}\\land e j^{(k-1)\\0\\右)\\,\\log(1-\\β)"

#: ../../source/library/models/epidemics/SEIS.rst:88
#: e2a80cda40fb4024b8232c365b8f73ae
msgid ""
"Node :math:`i` collects contributions from all neighbors :math:`N(i)` to "
"compute its exposure probability"
msgstr "节点 : math:`i'收集所有邻居的贡献 : math:`N(i)'计算其暴露概率"

#: ../../source/library/models/epidemics/SEIS.rst:90
#: 2dbccb3521604416a47829f5f212d723
msgid "m_i^{(k)} = 1 - \\exp\\!\\left( \\sum_{j \\in N(i)} m_{ji}^{(k)} \\right)"
msgstr "m i^{(k)}=1 -\\exp\\!\\左(\\sum {j\\in N(i)} m {ji}^{(k)}\\右)"

#: ../../source/library/models/epidemics/SEIS.rst:95
#: a68b24ab4818491d9d5aaa3aa9a8c14a
msgid ""
"The indicator variables are updated with independent uniform random "
"variables :math:`U_i^{\\mathrm{exp}}, U_i^{\\mathrm{inf}}, "
"U_i^{\\mathrm{rec}} \\sim \\mathrm{Uniform}(0,1)`"
msgstr ""
"指标变量以独立的统一随机变量更新 : math : `U i^{\\ mathrm{exp}}, U i^{\\ mathrm{inf}}, U "
"i^{\\ mathrm{rec}}\\sim\\mathrm{Uniform}(0,1)' 。"

#: ../../source/library/models/epidemics/SEIS.rst:97
#: 07a1887e86f94e08821692bbe6c36e37
msgid ""
"\\begin{aligned}\n"
" h_i^{(k)} &=\n"
"\\begin{cases}\n"
"    1, & \\text{if } (U_i^{\\mathrm{exp}} < m_i^{(k)}) \\land h_i^{(k-1)}=0 , \\\\[4pt]\n"
"    0, & \\text{if } (U_i^{\\mathrm{rec}} < \\gamma) \\land (h_i^{(k-1)}=1 \\land e_i^{(k-1)}=0), \\\\[4pt]\n"
"    h_i^{(k-1)}, & \\text{otherwise},\n"
"\\end{cases} \\\\[6pt]\n"
"e_i^{(k)} &=\n"
"\\begin{cases}\n"
"    1, & \\text{if } (U_i^{\\mathrm{exp}} < m_i^{(k)}) \\land h_i^{(k-1)}=0, \\\\[4pt]\n"
"    0, & \\text{if } (U_i^{\\mathrm{inf}} < \\alpha) \\land e_i^{(k-1)}=1 , \\\\[4pt]\n"
"    e_i^{(k-1)}, & \\text{otherwise},\n"
"\\end{cases} \\\\[6pt]\n"
"\\end{aligned}\n"
"\n"
msgstr ""
"开始{对齐}\n"
"h(k)}\n"
"开始{ cases}\n"
"1, &\\ text{if} (U i^{\\ mathrm{exp} < m i^{(k)})\\land h i^{(k-1)}=0,\\\\[4pt]\n"
"0, &\\text{if} (U i^{\\ mathrm{rec}} <\\gamma)\\land(h i^{(k-1)\\1)\\land e i^{(k-1)}\\\\[4pt]\n"
"h i^{(k-1)}, &\\ text{另类},\n"
"\\ end{ cases}\\\\\\ [6pt]\n"
"e i^{(k) }\n"
"开始{ cases}\n"
"1, &\\ text{if} (U i^{\\ mathrm{exp}} < m i^{(k)})\\land h i^{(k-1)}=0,\\\\[4pt]\n"
"0, &\\ text{if} (U i^{\\ mathrm{inf}}} <\\alpha)\\land e (k-1)}=1,\\\\[4pt]\n"
"e i  (k-1)}, &\\ text{另类},\n"
"\\ end{ cases}\\\\\\ [6pt]\n"
"结束{对齐}"

