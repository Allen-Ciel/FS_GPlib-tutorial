#: ../../source/library/models/epidemics/SEIR.rst:4
#: 8b23c474a6bb42e8b3204986b0620a26
msgid ""
"The SEIR Model [1]_ assumes that infection spreads only through links "
"between neighboring nodes in a graph :math:`G=(V,E)`. Each node is in one"
" of four states: :math:`S` (susceptible), :math:`E` (exposed/incubating),"
" :math:`I` (infected), or :math:`R` (recovered). A susceptible node "
":math:`i` becomes exposed by its infected neighbors :math:`j \\in N(i)` "
"with rate :math:`\\beta`, exposed nodes become infectious with rate "
":math:`\\alpha`, and infected nodes recover with rate :math:`\\gamma`:"
msgstr ""

#: ../../source/library/models/epidemics/SEIR.rst:9
#: 8f77f806971f436cb0be5681aa2c72e3
msgid ""
"\\begin{aligned}\n"
"\\frac{dS_i}{dt} &= -\\beta \\sum_{j\\in N(i)} S_i I_j, \\\\\n"
"\\frac{dE_i}{dt} &= \\beta \\sum_{j\\in N(i)} S_i I_j - \\alpha E_i, \\\\"
"\n"
"\\frac{dI_i}{dt} &= \\alpha E_i - \\gamma I_i, \\\\\n"
"\\frac{dR_i}{dt} &= \\gamma I_i .\n"
"\\end{aligned}"
msgstr ""

