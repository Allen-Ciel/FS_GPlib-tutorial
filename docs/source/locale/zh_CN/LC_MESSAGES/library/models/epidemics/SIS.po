#: ../../source/library/models/epidemics/SIS.rst:5
#: 3bc3f35ee8e54f88a35665c16106c9eb
msgid ""
"The SIS Model [1]_ assumes that infection spreads only through links "
"between neighboring nodes in a graph :math:`G=(V,E)`. Each node is in one"
" of two states: :math:`S` (susceptible) or :math:`I` (infected). A "
"susceptible node :math:`i` becomes infected by its infected neighbors "
":math:`j \\in N(i)` with rate :math:`\\beta`, while infected nodes "
"recover and become susceptible again with rate :math:`\\gamma`:"
msgstr ""

#: ../../source/library/models/epidemics/SIS.rst:10
#: 97d08a213f45443591f2d06598d499da
msgid ""
"\\begin{aligned}\n"
"\\frac{dS_i}{dt} &= -\\beta \\sum_{j\\in N(i)} S_i I_j + \\gamma I_i, "
"\\\\\n"
"\\frac{dI_i}{dt} &= \\beta \\sum_{j\\in N(i)} S_i I_j - \\gamma I_i .\n"
"\\end{aligned}"
msgstr ""

